{
  "name": "re-phraser-extension",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "Re-Phraser: Chrome MV3 extension that rewrites selected text using any AI chat - no API key, no automation, no telemetry.",
  "keywords": [
    "chrome-extension",
    "browser-extension",
    "manifest-v3",
    "text-rewriter",
    "ai",
    "productivity",
    "typescript",
    "react",
    "vite"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "icons": "node scripts/generate-icons.mjs",
    "release:check": "npm run typecheck && npm run test && npm run lint && npm run build",
    "package": "npm run build && node scripts/pack.mjs",
    "package:chrome": "npm run release:check && node scripts/pack.mjs --target=chrome",
    "package:edge": "npm run release:check && node scripts/pack.mjs --target=edge",
    "package:stores": "npm run package:chrome && npm run package:edge"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^24.0.0",
    "sharp": "^0.35.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vitest": "^1.5.2"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
